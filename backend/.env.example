# ===========================================
# E2M Hiring MCP Agent — Backend Configuration
# ===========================================
# Copy this file to .env and fill in your values

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Application ---
APP_NAME=E2M Hiring Agent
API_VERSION=v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://e2m-mcp-agent-frontend.vercel.app
ENVIRONMENT=development
DEBUG=true

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Groq LLM ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- EmailJS ---
EMAILJS_SERVICE_ID=your-service-id
EMAILJS_TEMPLATE_ID=your-template-id
EMAILJS_PUBLIC_KEY=your-public-key
EMAILJS_PRIVATE_KEY=your-private-key

# --- MCP Server Communication ---
MCP_INTERNAL_API_KEY=generate-a-secure-random-key-here

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
